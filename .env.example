# ==========================================================
# Variables de entorno para SiReSe (ProyectoFinal)
# Copia estos nombres en Render -> Environment -> Environment Variables
# NO subas tus valores reales al repositorio.
# ==========================================================

# --- Base de datos MySQL (OBLIGATORIO) ---
# Render NO ofrece MySQL gestionado: usa un MySQL externo
# (Railway, Aiven, Clever Cloud, o el de tu escuela).
# Formato de la URL JDBC:
DB_URL=jdbc:mysql://HOST:3306/NOMBRE_BD?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USER=tu_usuario
DB_PASSWORD=tu_contrasena

# --- Puerto ---
# Render lo asigna automáticamente. NO lo definas manualmente.
# La app ya lee ${PORT}.

# --- Correo SMTP (OPCIONAL) ---
# El envío de correos solo funciona si configuras estas variables
# Y agregas la sección spring.mail.* en application.properties
# (ver RENDER_DEPLOY.md). Si no las pones, el envío queda deshabilitado.
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=tucorreo@gmail.com
# MAIL_PASSWORD=clave_de_aplicacion
